{
  "name": "@arrow-js/highlight",
  "version": "1.0.2",
  "description": "ArrowJS-specific syntax highlighting helpers for embedded html template literals.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/standardagents/arrow-js",
    "directory": "packages/highlight"
  },
  "homepage": "https://github.com/standardagents/arrow-js#readme",
  "bugs": {
    "url": "https://github.com/standardagents/arrow-js/issues"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs index=src/index.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt",
    "arrow-logo.png"
  ]
}
